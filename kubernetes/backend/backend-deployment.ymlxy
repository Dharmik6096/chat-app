kind: Deployment 
apiVersion: apps/v1
metadata:
   name: chatapp-deployment 
   namespace: chat-app
spec:
   replicas: 2
   selector:
     matchLabels:
       app: chat-app 
   template:
     metadata:
       name: chatapp-pod
       namespace: chat-app
       lables:
         app: chat-app
     spec:
       containers:
       - name: backend 
         image: dp04/chatapp-backend:latest
         ports:
         - containerPort: 5001   
